{
  "version": 1,
  "spec": {
    "file": "SPECIFICATION.md",
    "maintained_heading_level": 3,
    "maintained_section_pattern": "^SPEC-[0-9]{3}-[A-Z]$"
  },
  "maintenance_rules": [
    "Maintain entries only for third-level specification sections such as SPEC-003-B.",
    "Map each section to the smallest set of primary code owners needed to understand or change that behavior.",
    "Prefer React components, exported domain functions, and named App handlers over line numbers.",
    "Exclude purely technical helpers unless a helper is the direct implementation of the spec behavior.",
    "Order targets from most important to least important for that section."
  ],
  "sections": {
    "SPEC-002-A": {
      "title": "Bundled fallback data",
      "targets": [
        {
          "file": "src/App.tsx",
          "component": "App",
          "functions": [
            "initialize"
          ],
          "role": "Loads bundled config and tasks during startup before any live repository refresh."
        },
        {
          "file": "scripts/sync-data.mjs",
          "role": "Copies data/config.json and data/tasks.json into public/data for the shipped fallback bundle."
        }
      ]
    },
    "SPEC-002-B": {
      "title": "Live repository mode",
      "targets": [
        {
          "file": "src/App.tsx",
          "component": "App",
          "functions": [
            "fetchRemoteState",
            "refreshFromRemote",
            "runRemoteMutation"
          ],
          "role": "Owns switching from fallback state to the live repository and writing mutations back immediately."
        },
        {
          "file": "src/logic/api.ts",
          "functions": [
            "fetchRepositoryJsonFile",
            "updateRepositoryJsonFile"
          ],
          "role": "Implements repository reads and writes through the GitHub API."
        }
      ]
    },
